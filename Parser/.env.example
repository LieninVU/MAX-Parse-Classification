# ============================================
# Конфигурация парсера каналов MAX
# ============================================
# Скопируйте этот файл в .env и измените значения:
#   copy .env.example .env

# Номер аккаунта (UserBot)
PHONE=+79933283681

# ──────────────────────────────────────────
# КАНАЛЫ ДЛЯ ПАРСИНГА
# ──────────────────────────────────────────
# Вариант 1: пусто — парсить ВСЕ доступные каналы
#   TARGET_CHANNEL_IDS=
#
# Вариант 2: указать конкретные ID через запятую
#   TARGET_CHANNEL_IDS=-71887474716883,-71409355871569,-68065767437739
#
# Чтобы узнать ID каналов — запустите парсер с пустым списком,
# в логе будут выведены все доступные каналы с их ID.
TARGET_CHANNEL_IDS=

# Папка для сессии (session.db)
WORK_DIR=./cache

# Путь к базе данных SQLite
DB_PATH=./messages.db

# Интервал опроса каналов (секунды)
POLL_INTERVAL=30

# Сколько последних сообщений забирать за один опрос
FETCH_BACKWARD=5

# ──────────────────────────────────────────
# ВЕБХУК НА СЕРВЕР АНАЛИТИКИ
# ──────────────────────────────────────────
ANALYTICS_WEBHOOK_URL=http://127.0.0.1:8000/webhook/post

# Таймаут отправки вебхука (секунды)
WEBHOOK_TIMEOUT=15

# Количество повторных попыток при сбое
WEBHOOK_RETRIES=2

# Задержка между попытками (секунды)
WEBHOOK_RETRY_DELAY=5

# Если true — при ошибке вебхука парсер НЕ останавливается
WEBHOOK_FAIL_SAFE=true

# ──────────────────────────────────────────
# ЛОГИРОВАНИЕ
# ──────────────────────────────────────────
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
