# ============================================
# Конфигурация сервера аналитики
# ============================================
# Скопируйте этот файл в .env и измените значения:
#   copy .env.example .env

# ──────────────────────────────────────────
# OpenRouter API
# ──────────────────────────────────────────
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# Модель LLM. Рекомендуемые:
#   qwen/qwen3.6-plus:free     — бесплатно, быстро
#   anthropic/claude-3.5-sonnet — лучший анализ
#   openai/gpt-4o-mini          — дешевле, быстрее
#   google/gemini-2.0-flash     — хороший баланс
OPENROUTER_MODEL=qwen/qwen3.6-plus:free

# Таймаут запроса к OpenRouter (секунды)
OPENROUTER_TIMEOUT=30

# ──────────────────────────────────────────
# ПАРАМЕТРЫ ПЕРЕПОДКЛЮЧЕНИЯ LLM
# ──────────────────────────────────────────
# Интервал проверки состояния соединения LLM (секунды)
LLM_CONNECTION_CHECK_INTERVAL=60

# Максимальное количество попыток переподключения LLM
LLM_MAX_RECONNECT_ATTEMPTS=3

# Базовая задержка перед переподключением LLM (секунды)
LLM_RECONNECT_BASE_DELAY=2

# Максимальная задержка перед переподключением LLM (секунды)
LLM_RECONNECT_MAX_DELAY=60

# Таймаут проверки состояния соединения LLM (секунды)
LLM_HEALTH_CHECK_TIMEOUT=10

# ──────────────────────────────────────────
# Сервер
# ──────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Путь к базе данных SQLite
DB_PATH=./analytics.db

# ──────────────────────────────────────────
# Логирование
# ──────────────────────────────────────────
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
